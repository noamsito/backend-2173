      "logs": "serverless logs -f generateBoleta --tail",
      "test": "jest",
      "test:watch": "jest --watch"
    },
    "dependencies": {
      "@aws-sdk/client-s3": "^3.490.0",
      "aws-lambda": "^1.0.7",
      "jspdf": "^2.5.1",
      "uuid": "^9.0.1",
      "dayjs": "^1.11.10"
    },
    "devDependencies": {
      "serverless": "^3.38.0",
      "serverless-offline": "^13.3.0",
      "serverless-random-string": "^1.0.1",
      "jest": "^29.7.0"
    },
    "engines": {
      "node": ">=18.0.0"
    },
