{
    "name": "boletas-pdf-service",
    "version": "1.0.0",
    "description": "Servicio Lambda para generar boletas PDF de compras de stocks",
    "main": "src/handlers/generateBoleta.js",
    "scripts": {
      "deploy": "serverless deploy",
      "deploy:dev": "serverless deploy --stage dev",
      "deploy:prod": "serverless deploy --stage prod",
      "remove": "serverless remove",
